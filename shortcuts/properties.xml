<properties>
    <!-- Property definitions -->
    <!-- Widget Aspect -->
	<property name="widgetAspect" type="options">
		<options>
		    <option value="Poster" label="$LOCALIZE[31262]" />
		    <option value="Square" label="$LOCALIZE[31263]" />
		    <option value="Landscape" label="$LOCALIZE[31462]" />
		    <option value="Thumbnail" label="$LOCALIZE[21371]" condition="!widgetPath~Weather" />
		</options>
	</property>	

    <!-- Widget Style (for Multi-Widgets) -->
    <property name="widgetStyle" type="options">
        <options>
            <option value="Poster" label="$LOCALIZE[31262]" />
            <option value="Square" label="$LOCALIZE[31263]" />
            <option value="Landscape" label="$LOCALIZE[31462]" />
            <option value="Thumbnail" label="$LOCALIZE[21371]" condition="!widgetPath~Weather" />
            <option value="LandscapeSmall" label="$LOCALIZE[31703]" condition="!widgetPath~Weather" />
            <option value="LandscapePosterSmall" label="$LOCALIZE[31704]" condition="!widgetPath~Weather + !widgetPath~studios + !widgetPath~genres + !widgetPath~countries" />
            <option value="Banner" label="$LOCALIZE[20020]" condition="!widgetPath~Weather + !widgetPath~studios + !widgetPath~genres + !widgetPath~countries" />
        </options>
    </property> 

    <!-- Widget Target -->
	<property name="widgetTarget" type="options">
		<options>
		    <option value="videos" label="$LOCALIZE[3]" />
		    <option value="music" label="$LOCALIZE[2]" />
		    <option value="pictures" label="$LOCALIZE[1]" />
		    <option value="programs" label="$LOCALIZE[10001]" />
		    <option value="favouritesbrowser" label="$LOCALIZE[1036]" />
		    <option value="games" label="$LOCALIZE[10821]" />
		    "
		</options>
	</property>

    <!-- Widget Sort by -->
	<property name="widgetSortby" templateonly="true" value="userpreference">
		<options>
            <option value="name" label="$LOCALIZE[551]" />
		    <option value="random" label="$LOCALIZE[590]" />
		    <option value="dateadded" label="$LOCALIZE[570]" />
		    <option value="lastplayed" label="$LOCALIZE[568]" />
		    <option value="playcount" label="$LOCALIZE[567]" condition="widgetType=movies | widgetType=sets | widgetType=tvshows | widgetType=episodes | widgetType=musicvideos | widgetType=albums | widgetType=songs" />
		    <option value="year" label="$LOCALIZE[345]" condition="widgetType=movies | widgetType=sets | widgetType=tvshows | widgetType=musicvideos | widgetType=albums | widgetType=songs" />
		    <option value="rating" label="$LOCALIZE[563]" condition="widgetType=movies | widgetType=sets | widgetType=tvshows | widgetType=episodes | widgetType=musicvideos | widgetType=albums | widgetType=songs" />
		    <option value="userrating" label="$LOCALIZE[38018]" condition="widgetTarget=videos | widgetTarget=music" />
		    <option value="votes" label="$LOCALIZE[205]" condition="widgetType=movies | widgetType=tvshows | widgetType=episodes" />
		    <option value="genre" label="$LOCALIZE[515]" condition="widgetType=movies | widgetType=sets | widgetType=tvshows | widgetType=musicvideos | widgetType=albums | widgetType=songs | widgetType=artists"/>
		    <option value="country" label="$LOCALIZE[574]" condition="widgetType=movies | widgetType=tvshows | widgetType=episodes" />
		    <option value="studio" label="$LOCALIZE[572]" condition="widgetType=movies | widgetType=tvshows | widgetType=episodes" />
		    <option value="playlist" label="$LOCALIZE[559]" condition="widgetPath~/playlists/" />
		    <option value="episode" label="$LOCALIZE[20359]" condition="widgetType=episodes" />
		    <option value="season" label="$LOCALIZE[20373]" condition="widgetType=episodes" />
		    <option value="totalepisodes" label="$LOCALIZE[20360]" condition="widgetType=tvshows" />
		    <option value="watchedepisodes" label="$LOCALIZE[21457]" condition="widgetType=tvshows" />
		    <option value="tvshowtitle" label="$LOCALIZE[36902]" condition="widgetType=episodes" />
		    <option value="file" label="$LOCALIZE[561]" condition="widgetType=movies | widgetType=episodes | widgetType=musicvideos | widgetType=songs | widgetType=pictures" />
		    <option value="title" label="$LOCALIZE[369]" />
		    <option value="tracknumber" label="$LOCALIZE[554]" condition="widgetType=musicvideos | widgetType=songs" />
		    <option value="time" label="$LOCALIZE[555]" condition="widgetType=movies | widgetType=tvshows | widgetType=episodes | widgetType=musicvideos | widgetType=albums | widgetType=songs" />
		    <option value="artist" label="$LOCALIZE[557]" condition="widgetType=musicvideos | widgetType=artists | widgetType=albums | widgetType=songs" />
		    <option value="album" label="$LOCALIZE[558]"  condition="widgetType=musicvideos | widgetType=albums | widgetType=songs" />
		    <option value="channelnumber" label="$LOCALIZE[19029]" condition="widgetType=pvr" />
		    <option value="lastupdated" label="$LOCALIZE[12014]" condition="widgetType=addons" />
		    <option value="lastused" label="$LOCALIZE[12012]" condition="widgetType=addons" />
		    <option value="date" label="$LOCALIZE[552]" condition="widgetType=episodes" />
		    <option value="userpreference" label="$LOCALIZE[19349]" />
		</options>
	</property>

    <!-- Widget Sorting -->
	<property name="widgetSortorder" type="options" templateonly="true">
		<options>
    		<option value="descending" label="$LOCALIZE[585]" />
    		<option value="ascending" label="$LOCALIZE[584]" />
		</options>
	</property>

    <!-- Widget Limit -->
	<property name="widgetLimit" type="options">
		<options>
		    <option value="10" label="$NUMBER[10]" />
		    <option value="25" label="$NUMBER[25]" />
		    <option value="50" label="$NUMBER[50]" />
		    <option value="100" label="$NUMBER[100]" />
		    <option value="Auto" label="$LOCALIZE[31821]" />
		</options>
	</property>

    <property name="widgetListType" templateonly="true" value="wraplist">
        <options>
            <option value="fixedlist" />
            <option value="wraplist" />
        </options>
    </property>

	<property name="widgetAutoscroll" type="toggle" />
    <property name="widgetFullscreen" type="toggle" />

    <!-- Button mappings -->					
	<buttons suffix="true">
		<button id="4001" property="widget" type="widget" />
		<button id="3007" property="widgetPath" type="text" title="Enter action"/>
        <button id="3005" property="widgetLabel" type="text" title="$LOCALIZE[528]"/>
		<button id="310" property="background" type="background" />
        <button id="350" property="widgetFullscreen" type="toggle" />
		<button id="351" property="widgetAspect" title="$LOCALIZE[31261]" showIcons="false" showNone="false" />
        <button id="352" property="widgetStyle" title="$LOCALIZE[31261]" showIcons="false" showNone="false" />
		<button id="353" property="widgetTarget" title="$LOCALIZE[31479]" showIcons="false" />
    	<button id="354" property="widgetSortby" title="$LOCALIZE[581]" showIcons="false" />
    	<button id="355" property="widgetSortorder" title="$LOCALIZE[580]" showIcons="false" />
        <button id="356" property="widgetLimit" title="$LOCALIZE[31822]" showIcons="false" />
    	<button id="357" property="widgetAutoscroll" title="$LOCALIZE[31340]" showIcons="false" />
        <button id="358" property="widgetListType" type="toggle" />
        <button id="359" property="widgetSortby" type="toggle" />
	</buttons>

    <!-- Fallback values -->
    <fallbacks>
        <fallback property="widgetAspect">
            <when condition="widgetType=movies">Poster</when>
            <when condition="widgetType=sets">Poster</when>
            <when condition="widgetType=tvshows">Poster</when>
            <when condition="widgetType=episodes">Thumbnail</when>
            <when condition="widgetType=games">Poster</when>
            <!-- Spotlight widget -->
            <when condition="!widgetPath">Poster</when>
            <default>Square</default>
        </fallback>
        <fallback property="widgetStyle">
            <when condition="widgetType=movies">Poster</when>
            <when condition="widgetType=sets">Poster</when>
            <when condition="widgetType=tvshows">Poster</when>
            <when condition="widgetType=episodes">Thumbnail</when>
            <when condition="widgetType=games">Poster</when>
            <default>Square</default>
        </fallback>
        <fallback property="widgetSortby">
            <when condition="widget=AllChannels">channelnumber</when>
            <when condition="widget=RadioAllChannels">channelnumber</when>
        </fallback>
    </fallbacks>

</properties>
